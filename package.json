{
  "name": "concurseiroos",
  "private": true,
  "version": "3.33.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "validate": "npm run validate:memory && npm run diagnostic:audit && npm run training:build && npm run training:audit && npm run knowledge:validate-official && npm run knowledge:build && npm run knowledge:build-taxonomy && npm run knowledge:build-curation && npm run knowledge:build-classification && npm run knowledge:build-routing && npm run learning:audit-error-recovery && npm run simulation:audit && npm run sde:audit && npm run readiness:audit && npm run typecheck && npm run test:run",
    "build": "npm run validate && npm run build:web && npm run build:server && npm run build:serverless",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "build:web": "vite build && npm run diagnostic:audit-built-assets && npm run training:audit-built-assets",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "vercel-build": "npm run build:web",
    "build:serverless": "esbuild src/server/httpApp.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/http-app.mjs && esbuild api/training-fgv/check.ts api/training-fgv/finalize.ts --bundle --platform=node --format=esm --packages=external --outbase=api --outdir=dist/serverless-api",
    "validate:memory": "node scripts/validateAiMemory.mjs",
    "knowledge:build": "node scripts/buildKnowledgeCatalog.mjs",
    "sde:audit": "tsx scripts/auditSdeReliability.ts",
    "knowledge:extract-official": "python scripts/buildOfficialFgvCorpus.py",
    "knowledge:validate-official": "node scripts/validateOfficialFgvCorpus.mjs",
    "knowledge:build-taxonomy": "tsx scripts/buildDataprevTaxonomy.ts",
    "knowledge:build-curation": "tsx scripts/buildCurationBacklog.ts",
    "readiness:audit": "tsx scripts/buildProductReadinessReport.ts",
    "knowledge:build-classification": "tsx scripts/buildQuestionClassificationProposals.ts",
    "knowledge:build-routing": "tsx scripts/buildPedagogicalRoutingReport.ts",
    "learning:audit-error-recovery": "tsx scripts/auditErrorRecoveryContract.ts",
    "simulation:audit": "tsx scripts/auditSimulationContract.ts",
    "diagnostic:audit": "node scripts/validatePilotDiagnostic.mjs",
    "diagnostic:audit-built-assets": "node scripts/validateBuiltDiagnosticAssets.mjs",
    "training:build": "node scripts/buildFgvTrainingCatalog.mjs",
    "training:audit": "node scripts/validateFgvTrainingCatalog.mjs",
    "training:audit-built-assets": "node scripts/validateBuiltFgvTrainingAssets.mjs",
    "training:smoke-serverless": "node scripts/smokeFgvTrainingServerless.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.2",
    "vite": "^6.2.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.13.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "24.x"
  }
}
