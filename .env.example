# ConcurseiroOS — configuração local
# Copie este arquivo para .env na raiz. Nunca comite o .env real.

# Gemini fica somente no servidor. Nunca use prefixo VITE_ para esta chave.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# disabled: libera explicitamente o modo sem login; optional: modo local; required: exige login.
# Em produção, optional é promovido para required. Use required explicitamente no deploy privado.
AUTH_MODE=optional

# false (recomendado): somente contas convidadas/criadas pelo administrador entram.
# true: exibe criação pública de conta. Não habilite em um aplicativo privado.
AUTH_ALLOW_SELF_SIGNUP=false

# Preferência para servidor/runtime. O endpoint /api/runtime-config expõe ao frontend
# somente URL e chave anon pública; nunca use SUPABASE_SERVICE_ROLE_KEY aqui.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Fallback de build. Útil em hospedagem estática, mas exige novo build/deploy ao alterar.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

VITE_SUPABASE_SNAPSHOT_TABLE=user_snapshots
VITE_SUPABASE_PRIVATE_BUCKET=private-study-materials
