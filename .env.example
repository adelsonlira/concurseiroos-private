# Backend-only Gemini key. Never prefix it with VITE_.
GEMINI_API_KEY=

# Production should require a valid Supabase access token for AI routes.
# Local development may use optional until the Supabase project is configured.
AUTH_MODE=optional

# Public Supabase project configuration used by the backend to validate tokens.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Public frontend configuration. Publishable/anon keys are safe to expose only
# because database and storage access are protected by authentication and RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SNAPSHOT_TABLE=user_snapshots
VITE_SUPABASE_PRIVATE_BUCKET=private-study-materials
